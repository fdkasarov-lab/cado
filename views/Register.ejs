<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cado</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" href="/icons/icon-192.png?v=2">
    <link rel="manifest" href="/manifest.webmanifest?v=3">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png?v=2">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png?v=2">
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/apple-touch-icon-167.png?v=2">
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png?v=2">
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon-120x120.png?v=2">
    <meta name="theme-color" content="#090E1E">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Cado">

</head>
<body>

<style>
    body {
        background: linear-gradient(180deg, #8e44ad, #3498db);
        height:calc(100vh);
        color:#fff;
        font-family: 'Open Sans', sans-serif !important;
    }
    form {
        position:absolute;
        top:50%;
        left:50%;
        transform:translate(-50%, -50%);
        background: rgba(0,0,0,0.5);
        padding:30px;
        width:340px;
        text-align:center;
        border-radius:16px;
        box-shadow:0 0 8px #000;
    }
    input {
        display:block;
        margin:auto;
        margin-bottom:16px;
        padding:12px 32px;
        background:none;
        border:none;
        border-bottom:3px solid #fff;
        width:160px;
        color:#fff;
        outline:none;
        letter-spacing:2px;
        font-size:15px;
        text-align:center;
        transition:0.25s;
    }
    input::placeholder {
        color:#eee;
    }
    input:focus {
        width:260px;
        border-color:#3498db;
    }
    button {
        background:linear-gradient(90deg, #8e44ad, #3498db);
        padding:20px 48px;
        font-size:16px;
        font-weight:bold;
        color:#fff;
        letter-spacing: 2px;
        text-transform:uppercase;
        border:none;
        text-align: center;
        border-radius:32px;
        outline:none;
    }
    button:hover {
        cursor:pointer;
    }
    a {
        color:#fff;
        font-family:cursive;
        letter-spacing:1px;
    }
    a:hover {
        color:#3498db;
    }
</style>
<div class="content">
<form id="register-login">
    <h1>Register</h1>
    <input type='email' id="username" required autocomplete="username" placeholder='Email'>
    <input type='password' id="password" required autocomplete="new-password" placeholder='Password'>
    <input type='text' inputmode="numeric" maxlength="6" id="pin" required placeholder='Pin'>
    <div class="error"></div>
    <button>Register</button>
</form>
    <a href="/login">Already registered? Login</a>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>
    const username = document.querySelector('#username')
    const password = document.querySelector('#password')
    const pin = document.querySelector('#pin')
    const display = document.querySelector('.error')
    const button = document.querySelector('button')
    const form = document.getElementById('register-login')

    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        display.textContent = ''
        button.disabled = true

        try {
            const res = await fetch('/api/auth/register', {
                method: 'POST',
                body: JSON.stringify({username: username.value.trim(), pin: pin.value.trim(), password: password.value}),
                headers: {'Content-Type': 'application/json'}
            })
            const data = await res.json()
            if (!res.ok) {
                return display.textContent = `${data.message}. ${data.error ? data.error : ''}`
            }

            localStorage.setItem('token',data.token)
            location.assign('/register/continue')
        } catch (err) {
            display.textContent = 'Unable to register. Please try again.'
        } finally {
            button.disabled = false
        }
    });

</script>
</body>
</html>
