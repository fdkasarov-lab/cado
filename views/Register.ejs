<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cado</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" href="/icons/icon-192.png?v=2">
    <link rel="manifest" href="/manifest.webmanifest?v=3">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png?v=2">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png?v=2">
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/apple-touch-icon-167.png?v=2">
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png?v=2">
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon-120x120.png?v=2">
    <meta name="theme-color" content="#0D1117">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Cado">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body {
            width: 100%; height: 100%;
            background: #0D1117;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            -webkit-font-smoothing: antialiased;
            overflow: hidden;
        }
        .auth-wrap {
            display: flex; align-items: center; justify-content: center;
            width: 100%; height: 100%;
            padding: 20px;
            background: radial-gradient(ellipse at 30% 20%, rgba(59,130,246,0.08) 0%, transparent 60%),
                        radial-gradient(ellipse at 70% 80%, rgba(139,92,246,0.06) 0%, transparent 60%),
                        #0D1117;
        }
        .auth-card {
            width: 100%; max-width: 380px;
            background: #161B22;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            padding: 36px 28px 28px;
            box-shadow: 0 8px 48px rgba(0,0,0,0.5);
            text-align: center;
        }
        .auth-logo {
            width: 52px; height: 52px;
            background: linear-gradient(135deg, #3B82F6, #8B5CF6);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
            font-size: 20px; color: #fff; font-weight: 700;
            box-shadow: 0 4px 14px rgba(59,130,246,0.35);
        }
        .auth-title {
            font-size: 22px; font-weight: 600;
            color: #E6EDF3; margin-bottom: 4px;
        }
        .auth-subtitle {
            font-size: 13px; color: #8B949E;
            margin-bottom: 28px;
        }
        .auth-input {
            width: 100%;
            background: #1F2937;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 10px;
            padding: 12px 14px;
            font-size: 14px; color: #E6EDF3;
            outline: none;
            transition: border-color 180ms, box-shadow 180ms;
            font-family: inherit;
            margin-bottom: 14px;
        }
        .auth-input::placeholder { color: #484F58; }
        .auth-input:focus {
            border-color: #3B82F6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.18);
        }
        .auth-btn {
            width: 100%;
            background: #3B82F6;
            border: none; border-radius: 10px;
            padding: 12px;
            font-size: 15px; font-weight: 600;
            color: #fff; cursor: pointer;
            font-family: inherit;
            transition: background 180ms, opacity 180ms;
            margin-top: 4px;
        }
        .auth-btn:hover { background: #2563EB; }
        .auth-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .auth-error {
            font-size: 13px; color: #F87171;
            min-height: 20px; margin: 8px 0 4px;
        }
        .auth-link {
            display: block; margin-top: 20px;
            font-size: 13px; color: #8B949E;
            text-decoration: none; transition: color 180ms;
        }
        .auth-link:hover { color: #3B82F6; }
    </style>
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-card">
            <div class="auth-logo">C</div>
            <div class="auth-title">Create account</div>
            <div class="auth-subtitle">Join Cado messenger</div>
            <form id="register-form">
                <input class="auth-input" type="email" id="username" required autocomplete="username" placeholder="Email">
                <input class="auth-input" type="password" id="password" required autocomplete="new-password" placeholder="Password (min 6 characters)">
                <input class="auth-input" type="text" inputmode="numeric" maxlength="6" id="pin" required placeholder="PIN (4 digits)">
                <div class="auth-error" id="error"></div>
                <button class="auth-btn" type="submit" id="registerBtn">Create Account</button>
            </form>
            <a class="auth-link" href="/login">Already registered? Sign in</a>
        </div>
    </div>
    <script>
        var username = document.getElementById('username')
        var password = document.getElementById('password')
        var pin = document.getElementById('pin')
        var error = document.getElementById('error')
        var btn = document.getElementById('registerBtn')
        var form = document.getElementById('register-form')

        form.addEventListener('submit', async function(e) {
            e.preventDefault()
            error.textContent = ''
            btn.disabled = true
            try {
                var res = await fetch('/api/auth/register', {
                    method: 'POST',
                    body: JSON.stringify({
                        username: username.value.trim(),
                        pin: pin.value.trim(),
                        password: password.value
                    }),
                    headers: { 'Content-Type': 'application/json' }
                })
                var data = await res.json()
                if (!res.ok) {
                    error.textContent = (data.error || data.message || 'Registration failed')
                    return
                }
                localStorage.setItem('token', data.token)
                location.assign('/')
            } catch (err) {
                error.textContent = 'Unable to register. Please try again.'
            } finally {
                btn.disabled = false
            }
        })
    </script>
</body>
</html>