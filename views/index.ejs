    /* ═══════════════════════════════════════════════════════════════
       WEBRTC VOICE CALL
       Single modal covers all states:
         outgoing  → "Calling…"  + Cancel
         incoming  → "Incoming"  + Decline | Accept
         connected → timer       + Mute | Speaker | Hang up
    ════════════════════════════════════════════════════════════════ */
    const ICE_SERVERS = {
        iceServers: [
            { urls: 'stun:stun.l.google.com:19302' },
            { urls: 'stun:stun1.l.google.com:19302' }
        ]
    }

    let peerConnection   = null
    let localStream      = null
    let remoteAudioCtx   = null   // for speaker toggle
    let remoteGainNode   = null
    let callTarget       = null
    let callRoom         = null
    let callTimerInt     = null
    let callSeconds      = 0
    let isMuted          = false
    let isSpeakerOff     = false
    let ringtoneCtx      = null   // inbound ringtone

    /* ── Modal helpers ── */
    function getContactAvatar(username) {
        const img = document.querySelector(`#iconList button[data-username="${username}"] img.user-avatar`)
        return img?.getAttribute('src') || null
    }

    function setModalAvatar(username) {
        const el  = document.getElementById('callModalAvatar')
        const src = getContactAvatar(username)
        const displayName = typeof getDisplayName === 'function' ? getDisplayName(username) : String(username || '?').split('@')[0]
        if (src) {
            el.innerHTML = `<img src="${src}" alt="${displayName}">`
        } else {
            el.textContent = (displayName || '?').charAt(0).toUpperCase()
        }
    }

    function showCallModal(username, state) {
        const modal      = document.getElementById('callModal')
        const nameEl     = document.getElementById('callModalName')
        const statusEl   = document.getElementById('callModalStatus')
        const primaryEl  = document.getElementById('callPrimaryBtns')
        const avatarEl   = document.getElementById('callModalAvatar')
        const minimizeBtn = document.getElementById('callMinimizeBtn')
        const secondaryEl = document.getElementById('callSecondaryBtns')

        var displayName = typeof getDisplayName === 'function' ? getDisplayName(username) : String(username || '').split('@')[0]
        nameEl.textContent = displayName
        setModalAvatar(username)
        modal.style.display = 'flex'
        modal.className = 'call-modal call-state-' + state

        avatarEl.className = 'call-modal-avatar'
        statusEl.className = 'call-modal-status'
        minimizeBtn.style.display = state === 'connected' ? 'flex' : 'none'
        if (secondaryEl) secondaryEl.style.display = state === 'connected' ? 'flex' : 'none'

        if (state === 'outgoing') {
            statusEl.textContent = 'Calling…'
            primaryEl.innerHTML = `
            <button class="call-primary-btn end" onclick="endCall()">
                <div class="call-primary-icon"><i class="fa-solid fa-phone-slash"></i></div>
                <span class="call-primary-label">Cancel</span>
            </button>`
        } else if (state === 'incoming') {
            statusEl.textContent = 'Incoming voice call'
            avatarEl.classList.add('ringing')
            primaryEl.innerHTML = `
            <button class="call-primary-btn end" onclick="declineCall()">
                <div class="call-primary-icon"><i class="fa-solid fa-phone-slash"></i></div>
                <span class="call-primary-label">Decline</span>
            </button>
            <button class="call-primary-btn accept" onclick="acceptCall(window._pendingOffer)">
                <div class="call-primary-icon"><i class="fa-solid fa-phone"></i></div>
                <span class="call-primary-label">Accept</span>
            </button>`
        } else if (state === 'connected') {
            statusEl.className = 'call-modal-status connected'
            statusEl.textContent = '00:00'
            avatarEl.classList.add('connected')
            primaryEl.innerHTML = `
            <button class="call-primary-btn end" onclick="endCall()">
                <div class="call-primary-icon"><i class="fa-solid fa-phone-slash"></i></div>
                <span class="call-primary-label">End</span>
            </button>`
            startCallTimer()
        }
    }

    function hideCallModal() {
        document.getElementById('callModal').style.display = 'none'
        document.getElementById('callMinimized').style.display = 'none'
        clearInterval(callTimerInt)
        callSeconds = 0
        document.getElementById('callModalStatus').textContent = ''
        document.getElementById('callModalStatus').className = 'call-modal-status'
        resetSecondaryBtns()
    }

    function minimizeCall() {
        document.getElementById('callModal').style.display = 'none'
        document.getElementById('callMinimized').style.display = 'flex'
        var avatar = document.getElementById('callModalAvatar')
        var minAvatar = document.getElementById('callMinAvatar')
        minAvatar.innerHTML = avatar.innerHTML
        document.getElementById('callMinName').textContent = document.getElementById('callModalName').textContent
        var status = document.getElementById('callModalStatus').textContent
        document.getElementById('callMinStatus').textContent = status || 'Connected'
    }

    function restoreCall() {
        document.getElementById('callMinimized').style.display = 'none'
        document.getElementById('callModal').style.display = 'flex'
        // Re-apply connected state timer if needed
        var statusEl = document.getElementById('callModalStatus')
        if (statusEl.classList.contains('connected')) {
            var sec = callSeconds
            var m = String(Math.floor(sec / 60)).padStart(2,'0')
            var s = String(sec % 60).padStart(2,'0')
            statusEl.textContent = m + ':' + s
        }
    }

    function resetSecondaryBtns() {
        const muteBtn    = document.getElementById('muteMicBtn')
        const speakerBtn = document.getElementById('speakerBtn')
        if (muteBtn) {
            muteBtn.classList.remove('toggled-off')
            muteBtn.querySelector('.call-secondary-icon').innerHTML = '<i class="fa-solid fa-microphone"></i>'
            muteBtn.querySelector('.call-secondary-label').textContent = 'Mute'
        }
        if (speakerBtn) {
            speakerBtn.classList.remove('toggled-off')
            speakerBtn.querySelector('.call-secondary-icon').innerHTML = '<i class="fa-solid fa-volume-high"></i>'
            speakerBtn.querySelector('.call-secondary-label').textContent = 'Speaker'
        }
    }

    function startCallTimer() {
        callSeconds = 0
        clearInterval(callTimerInt)
        callTimerInt = setInterval(() => {
            callSeconds++
            const m = String(Math.floor(callSeconds / 60)).padStart(2,'0')
            const s = String(callSeconds % 60).padStart(2,'0')
            const el = document.getElementById('callModalStatus')
            if (el) el.textContent = `${m}:${s}`
        }, 1000)
    }

    /* ── Toggle Mute ── */
    function toggleMute() {
        if (!localStream) return
        isMuted = !isMuted
        localStream.getAudioTracks().forEach(t => { t.enabled = !isMuted })
        const btn = document.getElementById('muteMicBtn')
        if (!btn) return
        const icon  = btn.querySelector('.call-secondary-icon')
        const label = btn.querySelector('.call-secondary-label')
        if (isMuted) {
            icon.innerHTML  = '<i class="fa-solid fa-microphone-slash"></i>'
            label.textContent = 'Unmute'
            btn.classList.add('toggled-off')
        } else {
            icon.innerHTML  = '<i class="fa-solid fa-microphone"></i>'
            label.textContent = 'Mute'
            btn.classList.remove('toggled-off')
        }
    }

    /* ── Toggle Speaker ── */
    function toggleSpeaker() {
        isSpeakerOff = !isSpeakerOff
        const remoteAudio = document.getElementById('remoteAudio')
        remoteAudio.muted = isSpeakerOff
        const btn = document.getElementById('speakerBtn')
        if (!btn) return
        const icon  = btn.querySelector('.call-secondary-icon')
        const label = btn.querySelector('.call-secondary-label')
        if (isSpeakerOff) {
            icon.innerHTML  = '<i class="fa-solid fa-volume-xmark"></i>'
            label.textContent = 'Speaker'
            btn.classList.add('toggled-off')
        } else {
            icon.innerHTML  = '<i class="fa-solid fa-volume-high"></i>'
            label.textContent = 'Speaker'
            btn.classList.remove('toggled-off')
        }
    }

    /* ── Ringtone for incoming calls ── */
    function startRingtone() {
        try {
            ringtoneCtx = new (window.AudioContext || window.webkitAudioContext)()
            function playBeep() {
                if (!ringtoneCtx) return
                var osc = ringtoneCtx.createOscillator()
                var gain = ringtoneCtx.createGain()
                osc.type = 'sine'
                osc.frequency.value = 440
                gain.gain.setValueAtTime(0.3, ringtoneCtx.currentTime)
                gain.gain.exponentialRampToValueAtTime(0.01, ringtoneCtx.currentTime + 0.5)
                osc.connect(gain)
                gain.connect(ringtoneCtx.destination)
                osc.start()
                osc.stop(ringtoneCtx.currentTime + 0.5)
            }
            var ringInterval = setInterval(function() {
                if (!ringtoneCtx) { clearInterval(ringInterval); return }
                playBeep()
                setTimeout(playBeep, 600)
            }, 2000)
            ringtoneCtx._interval = ringInterval
        } catch(e) {}
    }

    function stopRingtone() {
        if (ringtoneCtx) {
            clearInterval(ringtoneCtx._interval)
            ringtoneCtx.close().catch(function(){})
            ringtoneCtx = null
        }
    }

    /* ── Create peer connection ── */
    async function createPeerConnection() {
        peerConnection = new RTCPeerConnection(ICE_SERVERS)
        if (localStream) {
            localStream.getTracks().forEach(track => peerConnection.addTrack(track, localStream))
        }
        peerConnection.ontrack = (event) => {
            document.getElementById('remoteAudio').srcObject = event.streams[0]
        }
        peerConnection.onicecandidate = (event) => {
            if (event.candidate) {
                socket.emit('call:ice-candidate', {
                    candidate: event.candidate,
                    room:      callRoom,
                    target:    callTarget,
                    sender:    CurrentUser.getUsername()
                })
            }
        }
        peerConnection.onconnectionstatechange = () => {
            if (['disconnected','failed','closed'].includes(peerConnection?.connectionState)) {
                cleanupCall()
            }
        }
    }

    async function getMicrophone() {
        localStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    }

    /* ── Start a call ── */
    async function startCall() {
        if (!Interlocutor.getUsername()) return
        if (peerConnection) return
        callTarget = Interlocutor.getUsername()
        callRoom   = CurrentRoom.getName()
        try {
            await getMicrophone()
            await createPeerConnection()
            const offer = await peerConnection.createOffer()
            await peerConnection.setLocalDescription(offer)
            socket.emit('call:invite', { room: callRoom, caller: CurrentUser.getUsername(), callee: callTarget, offer })
            showCallModal(callTarget, 'outgoing')
        } catch (err) {
            console.error('startCall:', err)
            alert('Microphone access denied. Please allow microphone access and try again.')
            cleanupCall()
        }
    }

    /* ── Accept incoming call ── */
    async function acceptCall(offer) {
        stopRingtone()
        try {
            await getMicrophone()
            await createPeerConnection()
            await peerConnection.setRemoteDescription(new RTCSessionDescription(offer))
            const answer = await peerConnection.createAnswer()
            await peerConnection.setLocalDescription(answer)
            socket.emit('call:accept', { room: callRoom, caller: callTarget, callee: CurrentUser.getUsername(), answer })
            showCallModal(callTarget, 'connected')
        } catch (err) {
            console.error('acceptCall:', err)
            cleanupCall()
        }
    }

    /* ── Decline call ── */
    function declineCall() {
        stopRingtone()
        socket.emit('call:decline', { room: callRoom, caller: callTarget, callee: CurrentUser.getUsername() })
        hideCallModal()
        callTarget = null
        callRoom   = null
    }

    /* ── End / hang up ── */
    function endCall() {
        if (callRoom) {
            socket.emit('call:end', { room: callRoom, sender: CurrentUser.getUsername(), target: callTarget })
        }
        cleanupCall()
    }

    /* ── Full cleanup ── */
    function cleanupCall() {
        stopRingtone()
        if (peerConnection) { peerConnection.close(); peerConnection = null }
        if (localStream)    { localStream.getTracks().forEach(t => t.stop()); localStream = null }
        const audio = document.getElementById('remoteAudio')
        if (audio) { audio.srcObject = null; audio.muted = false }
        hideCallModal()
        isMuted      = false
        isSpeakerOff = false
        callTarget   = null
        callRoom     = null
    }

    /* ═══════════════════════════════════════════════════════════════
       SOCKET INIT
    ═══════════════════════════════════════════════════════════════ */
const CurrentUser  = new UserObj()
const Interlocutor = new UserObj()
const CurrentRoom  = new Room()

// ══ E2E Encryption Module ══════════════════════════════════════════════════
const E2E = {
    _ready: null,

    async init() {
        if (this._ready) return this._ready
        this._ready = this._doInit().catch(function() {})
        return this._ready
    },

    async _doInit() {
        const stored = localStorage.getItem('e2e_keypair')
        if (stored) {
            const { pub, priv } = JSON.parse(stored)
            const publicKey = await crypto.subtle.importKey('jwk', pub, { name: 'ECDH', namedCurve: 'P-256' }, true, [])
            const privateKey = await crypto.subtle.importKey('jwk', priv, { name: 'ECDH', namedCurve: 'P-256' }, false, ['deriveBits'])
            this._keyPair = { publicKey, privateKey }
            return pub
        }
        return this._generate()
    },

    async _generate() {
        const kp = await crypto.subtle.generateKey({ name: 'ECDH', namedCurve: 'P-256' }, true, ['deriveBits'])
        const pub = await crypto.subtle.exportKey('jwk', kp.publicKey)
        const priv = await crypto.subtle.exportKey('jwk', kp.privateKey)
        localStorage.setItem('e2e_keypair', JSON.stringify({ pub, priv }))
        this._keyPair = kp
        return pub
    },

    _getStoredPub() {
        const s = localStorage.getItem('e2e_keypair')
        return s ? JSON.parse(s).pub : null
    },

    async _deriveKey(username) {
        await this._ready
        if (!this._keyPair) { console.warn('[E2E] _deriveKey: no _keyPair'); return null }
        const cacheKey = 'e2e_shared_' + username
        const cached = localStorage.getItem(cacheKey)
        if (cached) {
            const raw = new Uint8Array(Object.values(JSON.parse(cached)))
            return await crypto.subtle.importKey('raw', raw, { name: 'AES-GCM' }, false, ['encrypt', 'decrypt'])
        }
        const resp = await fetch('/api/crypto/pubkey/' + encodeURIComponent(username))
        if (!resp.ok) { console.warn('[E2E] _deriveKey: fetch failed for', username, resp.status); return null }
        const peerJwk = await resp.json()
        console.log('[E2E] _deriveKey: peerJwk keys:', Object.keys(peerJwk).join(','), 'kty:', peerJwk.kty, 'crv:', peerJwk.crv)
        const peerKey = await crypto.subtle.importKey('jwk', peerJwk, { name: 'ECDH', namedCurve: 'P-256' }, true, [])
        const shared = await crypto.subtle.deriveBits({ name: 'ECDH', public: peerKey }, this._keyPair.privateKey, 256)
        const hash = await crypto.subtle.digest('SHA-256', shared)
        const bytes = new Uint8Array(hash)
        console.log('[E2E] _deriveKey: derived key fingerprint:', Array.from(bytes.slice(0,4)).map(function(b){return b.toString(16).padStart(2,'0')}).join(''))
        localStorage.setItem(cacheKey, JSON.stringify(Array.from(bytes)))
        return await crypto.subtle.importKey('raw', bytes, { name: 'AES-GCM' }, false, ['encrypt', 'decrypt'])
    },

    async encrypt(username, plaintext) {
        if (!plaintext) return plaintext
        const key = await this._deriveKey(username)
        if (!key) return plaintext
        const iv = crypto.getRandomValues(new Uint8Array(12))
        const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, new TextEncoder().encode(plaintext))
        return '__e2e__' + btoa(String.fromCharCode(...iv)) + '.' + btoa(String.fromCharCode(...new Uint8Array(ct)))
    },

    async decrypt(username, text) {
        if (!text || !text.startsWith('__e2e__')) return text
        const p = text.slice(7)
        const m = p.indexOf('.')
        if (m === -1) return text
        const iv = new Uint8Array(atob(p.slice(0, m)).split('').map(function(c){return c.charCodeAt(0)}))
        const ct = new Uint8Array(atob(p.slice(m + 1)).split('').map(function(c){return c.charCodeAt(0)}))
        console.log('[E2E] decrypt username:', username, 'iv len:', iv.length, 'ct len:', ct.length, 'ct hex0:', Array.from(ct.slice(0,4)).map(function(b){return b.toString(16).padStart(2,'0')}).join(''))
        const key = await this._deriveKey(username)
        if (!key) { console.warn('[E2E] decrypt: no key for', username); return text }
        console.log('[E2E] decrypt: key obtained, attempting decrypt')
        const plain = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, key, ct)
        return new TextDecoder().decode(plain)
    }
}
// ════════════════════════════════════════════════════════════════════════════

const socket = io()
window.socket      = socket   // expose for FCM module
window.CurrentRoom = CurrentRoom
const form   = document.getElementById('form')

    if (!localStorage.getItem('token') || localStorage.getItem('token') === 'null') {
        window.location = window.location.origin + '/login'
    }

    socket.emit('jwtCheck', localStorage.getItem('token'))

    socket.on('JwtSuccess', (tokenResult) => {
        if (tokenResult.username) {
            CurrentUser.setUsername(tokenResult.username)
            CurrentUser.setId(tokenResult.id)
            // Init E2E first so decrypt calls wait for ready
            E2E.init().then(function(pub) {
                if (pub) fetch('/api/crypto/pubkey', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ publicKey: pub })
                }).catch(function(){})
            }).catch(function(){})
            getChatMessages(tokenResult.username)
            socket.emit('userOnline', { username: tokenResult.username })
            // Request push permission and save FCM token
            if (window.__setupFCMPush) {
                window.__setupFCMPush(tokenResult.username)
            }
            applyChatCfg().catch(function(){})
        } else {
            window.location = window.location.origin + '/login'
        }
    })

    /* ── Presence ── */
    socket.on('userOnline', (data) => {
        userStatus[data.username] = { online: true, lastSeen: null }
        updateStatusLabel(data.username, 'online')
    })
    socket.on('userOffline', (data) => {
        userStatus[data.username] = { online: false, lastSeen: new Date(data.lastSeen || Date.now()) }
        updateStatusLabel(data.username, 'offline')
        // If offline mid-call, clean up
        if (data.username === callTarget) cleanupCall()
    })
    socket.on('userStatus', (data) => {
        userStatus[data.username] = { online: data.online, lastSeen: data.lastSeen ? new Date(data.lastSeen) : null }
        updateStatusLabel(data.username, data.online ? 'online' : 'offline')
    })

    /* ── Typing ── */
    socket.on('typing', (data) => {
        if (data.sender === Interlocutor.getUsername()) updateStatusLabel(data.sender, 'typing')
    })
    socket.on('stopTyping', (data) => {
        if (data.sender === Interlocutor.getUsername()) {
            const info = userStatus[data.sender]
            updateStatusLabel(data.sender, info?.online ? 'online' : 'offline')
        }
    })

    /* ═══════════════════════════════════════════════════════════════
       WEBRTC SIGNALING — socket events
    ═══════════════════════════════════════════════════════════════ */

    // Someone is calling us
    socket.on('call:invite', async (data) => {
        if (peerConnection) {
            socket.emit('call:decline', { room: data.room, caller: data.caller, callee: CurrentUser.getUsername() })
            return
        }
        callTarget           = data.caller
        callRoom             = data.room
        window._pendingOffer = data.offer
        showCallModal(data.caller, 'incoming')
        startRingtone()
    })

    // Our call was accepted
    socket.on('call:accepted', async (data) => {
        if (!peerConnection) return
        try {
            await peerConnection.setRemoteDescription(new RTCSessionDescription(data.answer))
            showCallModal(callTarget, 'connected')
        } catch (err) {
            console.error('call:accepted error:', err)
            cleanupCall()
        }
    })

    // Our call was declined
    socket.on('call:declined', (data) => {
        cleanupCall()
        // Brief notification in header status
        const text = document.getElementById('statusText')
        if (text) {
            text.textContent = 'Call declined'
            setTimeout(() => updateStatusLabel(callTarget, userStatus[callTarget]?.online ? 'online' : 'offline'), 3000)
        }
    })

    // Call ended by the other person
    socket.on('call:ended', (data) => {
        cleanupCall()
    })

    // ICE candidates from the other peer
    socket.on('call:ice-candidate', async (data) => {
        if (!peerConnection) return
        try {
            await peerConnection.addIceCandidate(new RTCIceCandidate(data.candidate))
        } catch (err) {
            console.error('ICE candidate error:', err)
        }
    })

    /* ═══════════════════════════════════════════════════════════════
       CHAT MESSAGES
    ═══════════════════════════════════════════════════════════════ */
    form.addEventListener('submit', function (e) {
        e.preventDefault()
        if (Interlocutor.getUsername() && input.value.trim()) {
            socket.emit('stopTyping', { room: CurrentRoom.getName(), sender: CurrentUser.getUsername(), receiver: Interlocutor.getUsername() })
            clearTimeout(typingTimer)
            var msg = input.value.trim()
            E2E.encrypt(Interlocutor.getUsername(), msg).then(function(encrypted) {
                socket.emit('chat message', { room: CurrentRoom.getName(), message: encrypted, sender: CurrentUser.getUsername(), receiver: Interlocutor.getUsername() })
            })
            input.value = ''
        }
    })

    socket.on("chat message", (data) => {
        const li = document.createElement("li")
        li.classList.add('message-bubble')
        li.setAttribute('id', data.message._id)
        li.setAttribute('data-read', data.message.isRead)
        if (data.message.receiver === CurrentUser.getUsername()) {
            li.classList.add('bubble-received')
        } else {
            li.classList.add('bubble-sent')
            let isRead = document.createElement('span')
            isRead.classList.add('isRead')
            li.appendChild(isRead)
        }
        let ImageBox = document.createElement('div')
        let date     = new Date(data.message.created_at)
        let msgDate  = document.createElement('span')
        const files = Array.isArray(data.message.files) ? data.message.files : []
        if (files.length && files[0].startsWith('stickers/')) li.classList.add('sticker-msg')
        if (files.length !== 0) {
            if (files.length === 1) {
                ImageBox.classList.add('MsgImage')
                if (files[0].startsWith('stickers/') && files[0].endsWith('.webm')) {
                    let video = document.createElement('video')
                    video.setAttribute('src', files[0])
                    video.classList.add('image')
                    video.muted = true
                    video.autoplay = true
                    video.loop = true
                    video.playsInline = true
                    ImageBox.appendChild(video)
                } else {
                    let image = document.createElement('img')
                    image.setAttribute('src', files[0].startsWith('stickers/') ? files[0] : 'uploads/' + files[0])
                    image.classList.add('image')
                    image.setAttribute('onclick', 'openImage(this)')
                    image.setAttribute('data-img', files[0])
                    ImageBox.appendChild(image)
                }
            } else {
                ImageBox.classList.add('MsgImages')
                files.forEach(function (item) {
                    if (item.startsWith('stickers/') && item.endsWith('.webm')) {
                        let video = document.createElement('video')
                        video.setAttribute('src', item)
                        video.classList.add('image')
                        video.muted = true
                        video.autoplay = true
                        video.loop = true
                        video.playsInline = true
                        ImageBox.appendChild(video)
                    } else {
                        let image = document.createElement('img')
                        image.setAttribute('src', item.startsWith('stickers/') ? item : 'uploads/' + item)
                        image.classList.add('image')
                        image.setAttribute('onclick', 'openImage(this)')
                        image.setAttribute('data-img', item)
                        ImageBox.appendChild(image)
                    }
                })
            }
        }
        let messageText = document.createElement('p')
        messageText.classList.add('messageText')
        var decryptPeer = data.message.sender === CurrentUser.getUsername() ? data.message.receiver : data.message.sender
        var isEncrypted = typeof data.message.message === 'string' && data.message.message.startsWith('__e2e__')
        messageText.textContent = isEncrypted ? '\u{1F512} Encrypted message' : data.message.message
        if (isEncrypted) {
            E2E.decrypt(decryptPeer, data.message.message).then(function(d) {
                messageText.textContent = d
                if (chatBtn) {
                    var pv = chatBtn.querySelector('.chat-item-preview')
                    if (pv) {
                        var t = d || (data.message.files && data.message.files.length > 0 ? 'Photo' : '')
                        pv.textContent = t.length > 50 ? t.slice(0, 50) + '...' : t
                    }
                }
            }).catch(function(e){ console.error('[E2E] decrypt error:', e && e.message ? e.message : e) })
        }
        msgDate.textContent = date.getHours() + ':' + String(date.getMinutes()).padStart(2,'0')
        msgDate.classList.add('messageDate')
        li.appendChild(messageText)
        messageText.appendChild(ImageBox)
        li.appendChild(msgDate)
        li.setAttribute('data-created', data.message.created_at)
        li.setAttribute('data-id', data.message._id)
        const messages = document.getElementById(data.message.chat_Id).querySelector('ul')
        messages.appendChild(li)
        let temp    = document.getElementById(data.message.chat_Id)
        let element = temp.querySelector('.msg-panel')
        let closeBtn = document.getElementById('closeImgUpload')
        if (closeBtn) closeBtn.click()
        const chatUsername = data.message.sender === CurrentUser.getUsername() ? data.message.receiver : data.message.sender
        const chatBtn = document.querySelector(`#iconList .chat-item-btn[data-username="${chatUsername}"]`)
        if (chatBtn) {
            const preview = chatBtn.querySelector('.chat-item-preview')
            const timeEl = chatBtn.querySelector('.chat-item-time')
            if (preview) {
                var raw = data.message.message
                if (typeof raw === 'string' && raw.startsWith('__e2e__')) {
                    preview.textContent = '\u{1F512} Encrypted'
                } else {
                    var txt = raw || (data.message.files && data.message.files.length > 0 ? 'Photo' : '')
                    preview.textContent = txt.length > 50 ? txt.slice(0, 50) + '...' : txt
                }
            }
            if (timeEl) {
                const d = new Date(data.message.created_at)
                const now = new Date()
                timeEl.textContent = d.toDateString() === now.toDateString()
                    ? String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0')
                    : d.toLocaleDateString()
            }
            const li = chatBtn.closest('.chat-list-item')
            const list = document.getElementById('iconList')
            if (li && list) list.prepend(li)
        }
        if (data.message.receiver !== CurrentUser.getUsername()) {
            element.scrollTop = element.scrollHeight
        } else {
            const chatIsActive = CurrentRoom.getName() === data.message.chat_Id && document.visibilityState === 'visible'
            if (!chatIsActive) {
                const span = document.querySelector(`#iconList span.unread-indicator[data-user-name="${chatUsername}"]`)
                if (span) {
                    span.textContent = (parseInt(span.textContent) || 0) + 1
                    span.classList.remove('d-none')
                }
            } else {
                if (element.scrollTop + element.clientHeight + 80 >= element.scrollHeight) {
                    socket.emit('messageRead', { id: data.message._id })
                }
            }
        }
    })

    socket.on('Read', (data) => {
        let el = document.getElementById(data._id)
        if (!el) return
        if (data.sender === CurrentUser.getUsername()) {
            let indicator = el.querySelector('.isRead')
            if (indicator) indicator.remove()
        }
        el.setAttribute('data-read', true)
    })

    socket.on("JoinedNew", (IncomingData) => {
        let data = IncomingData.room
        let CreateChatData = {}
        if (data.firstMember === CurrentUser.getUsername()) {
            CreateChatData.username = data.SecondMember
        } else if (data.SecondMember === CurrentUser.getUsername()) {
            CreateChatData.username = data.firstMember
        }
        CreateChatData.room = data.chatId
        CreateChatData.pending = data.pending
        CreateChatData.requester = data.requester
        createChat(CreateChatData)
        setChatAvatar(CreateChatData.username)
        const info = document.getElementById("info")
        if (info) info.remove()
        let OpenTab      = document.querySelector(`button[data-username="${CreateChatData.username}"]`)
        let closeProfile = document.getElementById('closeViewProfile')
        let element      = document.getElementById('iconList')
        element.scrollTop = element.scrollHeight
        Interlocutor.setUsername(CreateChatData.username)
        CurrentRoom.SetName(CreateChatData.room)
        enterChatMode(CreateChatData.username)
        if (closeProfile) {
            closeProfile.click()
            if (OpenTab) OpenTab.click()
        } else {
            SetListeners(true)
        }
    })

    document.addEventListener('visibilitychange', () => {
        if (!document.hidden && CurrentUser.getUsername()) {
            socket.emit('userOnline', { username: CurrentUser.getUsername() })
        }
    })

    // End call on tab close
    window.addEventListener('beforeunload', function() {
        if (callRoom) {
            socket.emit('call:end', { room: callRoom, sender: CurrentUser.getUsername(), target: callTarget })
        }
    })

    // Escape to end/decline call
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && document.getElementById('callModal').style.display === 'flex') {
            var modal = document.getElementById('callModal')
            if (modal.querySelector('.call-primary-btn.accept')) {
                declineCall()
            } else {
                endCall()
            }
        }
    })

    // init nav background slider position
    const initSlider = () => {
        const btn = document.querySelector('.nav-btn.active')
        const slider = document.getElementById('navBgSlider')
        if (btn && slider) slider.style.left = btn.offsetLeft + 'px'
    }
    initSlider()
    window.addEventListener('resize', initSlider)
</script>
</body>
</html>
