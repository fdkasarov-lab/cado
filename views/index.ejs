<!-- ══ FIREBASE CLIENT SDK ════════════════════════════════════════════════ -->
<script type="module">
    import { initializeApp }  from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js'
    import { getMessaging, getToken, onMessage } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-messaging.js'

    const firebaseConfig = {
        apiKey: "AIzaSyD_aHPsTnrOoTI1CrykPQmn6aKWJGgPy-c",
        authDomain: "cado-a1b6d.firebaseapp.com",
        projectId: "cado-a1b6d",
        storageBucket: "cado-a1b6d.firebasestorage.app",
        messagingSenderId: "148347344602",
        appId: "1:148347344602:web:b3cac6acf3c812fd4a37e3",
        measurementId: "G-S7ZCZ249ET"
    }
    const VAPID_KEY = "BAYa9b-6-9hTS82CEeFG1gM9ttl0vv5mtzkCkM7HwrBNitXXV1Cuc5AedkdpeXGY4yRKhtC_KwKkz19K8eXuXac"

    const app = initializeApp(firebaseConfig)

    function isIosDevice() {
        return /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1)
    }

    function isStandaloneApp() {
        return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true
    }

    function isMessagingSupported() {
        return (
            typeof window !== 'undefined' &&
            'serviceWorker' in navigator &&
            'Notification' in window &&
            'PushManager' in window &&
            (location.protocol === 'https:' || location.hostname === 'localhost')
        )
    }

    let messaging = null
    if (isMessagingSupported()) {
        try { messaging = getMessaging(app) }
        catch (err) { console.warn('[FCM] getMessaging failed:', err.message) }
    } else {
        console.warn('[FCM] Push requires HTTPS and browser push support')
    }

    async function registerSW() {
        if (!('serviceWorker' in navigator)) return null
        try {
            const existing = await navigator.serviceWorker.getRegistration('/')
            if (existing) await existing.update()
            const reg = existing || await navigator.serviceWorker.register('/firebase-messaging-sw.js', { scope: '/' })
            console.log('[FCM] Service Worker ready:', reg.scope)
            return reg
        } catch (err) {
            console.error('[FCM] SW registration failed:', err)
            return null
        }
    }

    function removePushPrompt() {
        document.getElementById('pushPrompt')?.remove()
    }

    function showPushPrompt(username, mode = 'enable') {
        removePushPrompt()

        const isInstallHint = mode === 'install'
        const prompt = document.createElement('div')
        prompt.id = 'pushPrompt'
        prompt.className = 'fcm-toast push-prompt'
        prompt.innerHTML = `
            <div class="fcm-toast-icon"><i class="fa-solid ${isInstallHint ? 'fa-mobile-screen-button' : 'fa-bell'}"></i></div>
            <div class="fcm-toast-text">
                <div class="fcm-toast-title">${isInstallHint ? 'Install Cado' : 'Enable notifications'}</div>
                <div class="fcm-toast-body">${isInstallHint ? 'On iPhone/iPad, add Cado to Home Screen, open it there, then enable notifications.' : 'Get message and call alerts on this device.'}</div>
            </div>
            ${isInstallHint ? '' : '<button class="push-enable-btn" id="pushEnableBtn">Enable</button>'}
            <button class="fcm-toast-close" id="pushCloseBtn"><i class="fa-solid fa-xmark"></i></button>`

        document.body.appendChild(prompt)
        document.getElementById('pushCloseBtn')?.addEventListener('click', removePushPrompt)
        document.getElementById('pushEnableBtn')?.addEventListener('click', () => setupPush(username, true))
    }

    async function setupPush(username, fromUserAction = false) {
        if (!username) return

        if (window.NativeFCMToken) {
            console.log('[FCM] Using native token from WebView bridge')
            await saveFcmToken(username, window.NativeFCMToken)
            return
        }

        if (isIosDevice() && !isStandaloneApp()) {
            showPushPrompt(username, 'install')
            return
        }

        if (!messaging) {
            console.warn('[FCM] Skipping push setup - messaging not available')
            return
        }

        try {
            if (Notification.permission === 'default' && !fromUserAction) {
                showPushPrompt(username)
                return
            }

            const permission = Notification.permission === 'granted'
                ? 'granted'
                : await Notification.requestPermission()

            if (permission !== 'granted') {
                console.log('[FCM] Notification permission denied')
                return
            }

            const swReg = await registerSW()
            if (!swReg) return

            const token = await getToken(messaging, {
                vapidKey: VAPID_KEY,
                serviceWorkerRegistration: swReg
            })

            if (token) {
                console.log('[FCM] Token obtained')
                await saveFcmToken(username, token)
                if (window.socket) window.socket.emit('saveFcmToken', { username, token })
                removePushPrompt()
            }
        } catch (err) {
            console.error('[FCM] Push setup error:', err)
            if (isIosDevice() && !isStandaloneApp()) showPushPrompt(username, 'install')
        }
    }

    // Save token to server ───────────────────────────────────────────────
    async function saveFcmToken(username, token) {
        try {
            const previousToken = localStorage.getItem('fcmToken')
            const previousUsername = localStorage.getItem('fcmTokenUsername') || username
            if (previousToken && previousToken !== token) {
                await fetch('/fcm/token/remove', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ username: previousUsername, token: previousToken })
                })
            }

            await fetch('/fcm/token', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ username, token })
            })
            localStorage.setItem('fcmToken', token)
            localStorage.setItem('fcmTokenUsername', username)
            console.log('[FCM] Token saved to server')
        } catch (err) {
            console.error('[FCM] Failed to save token:', err)
        }
    }

    // ── Foreground message handler ─────────────────────────────────────────
    if (messaging) {
        onMessage(messaging, (payload) => {
            console.log('[FCM] Foreground message:', payload)
            const data  = payload.data || {}
            const notif = payload.notification || {}
            if (data.type === 'call') return
            const isChatOpen = window.CurrentRoom?.getName() === data.chatId
            if (!isChatOpen) showToast(data.title || notif.title || 'New message', data.body || notif.body || '')
        })
    }

    // ── In-app toast ──────────────────────────────────────────────────────
    function showToast(title, body) {
        const existing = document.getElementById('fcmToast')
        if (existing) existing.remove()
        const toast = document.createElement('div')
        toast.id = 'fcmToast'
        toast.className = 'fcm-toast'
        toast.innerHTML = `
            <div class="fcm-toast-icon"><i class="fa-solid fa-message"></i></div>
            <div class="fcm-toast-text">
                <div class="fcm-toast-title">${title}</div>
                <div class="fcm-toast-body">${body}</div>
            </div>
            <button class="fcm-toast-close" onclick="this.parentElement.remove()">
                <i class="fa-solid fa-xmark"></i>
            </button>`
        document.body.appendChild(toast)
        setTimeout(() => toast?.remove(), 5000)
    }

    // ── Service worker messages (notification clicks) ─────────────────────
    navigator.serviceWorker?.addEventListener('message', (event) => {
        const { type, data, action } = event.data || {}
        if (type === 'NOTIFICATION_CLICK') {
            if (data?.chatId) {
                const btn = document.querySelector(`button[data-room="${data.chatId}"]`)
                if (btn) btn.click()
            }
        }
        if (type === 'CALL_DECLINED_FROM_NOTIFICATION') {
            if (window.declineCall) declineCall()
        }
    })

    window.__setupFCMPush = setupPush
</script>

