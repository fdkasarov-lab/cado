<script>
    /* ═══════════════════════════════════════════════════════════════
       STATUS SYSTEM
    ════════════════════════════════════════════════════════════════ */
    const userStatus = {}

    function formatLastSeen(date) {
        if (!date) return 'Last seen a long time ago'
        const now  = new Date()
        const diff = Math.floor((now - date) / 1000)
        if (diff < 30)   return 'Last seen just now'
        if (diff < 60)   return `Last seen ${diff} seconds ago`
        if (diff < 120)  return 'Last seen 1 minute ago'
        if (diff < 3600) return `Last seen ${Math.floor(diff / 60)} minutes ago`
        if (diff < 7200) return 'Last seen 1 hour ago'
        const isYesterday = date.getDate() === now.getDate() - 1 &&
            date.getMonth() === now.getMonth() && date.getFullYear() === now.getFullYear()
        const h = String(date.getHours()).padStart(2,'0')
        const m = String(date.getMinutes()).padStart(2,'0')
        if (isYesterday) return `Last seen yesterday at ${h}:${m}`
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
        return `Last seen ${months[date.getMonth()]} ${date.getDate()}, ${h}:${m}`
    }

    function updateStatusLabel(username, state) {
        if (!username || Interlocutor.getUsername() !== username) return
        const dot  = document.getElementById('statusDot')
        const text = document.getElementById('statusText')
        if (!dot || !text) return
        if (state === 'typing') {
            dot.className = 'status-dot typing'
            text.className = 'status-typing-text'
            text.textContent = 'Typing...'
        } else if (state === 'online') {
            dot.className = 'status-dot online'
            text.className = ''
            text.textContent = 'Online'
        } else {
            const info = userStatus[username]
            dot.className = 'status-dot offline'
            text.className = ''
            text.textContent = formatLastSeen(info?.lastSeen || null)
        }
        const chatItem = document.querySelector(`#iconList button[data-username="${username}"]`)
        if (chatItem) {
            let dot = chatItem.querySelector('.chat-status-dot')
            if (!dot) {
                dot = document.createElement('span')
                dot.classList.add('chat-status-dot')
                chatItem.querySelector('.chat-item-avatar').appendChild(dot)
            }
            dot.className = 'chat-status-dot ' + (state === 'offline' ? 'offline' : 'online')
        }
    }

    /* ═══════════════════════════════════════════════════════════════
       LAYOUT — sidebar ↔ chat header
    ═══════════════════════════════════════════════════════════════ */
    const appShell = document.getElementById('appShell')
    const tabViews = document.getElementById('tabViews')
    const bottomNav = document.getElementById('bottomNav')

    async function enterChatMode(username) {
        _lastChatUser = username
        appShell.classList.add('chat-open')
        tabViews.classList.add('hidden')
        bottomNav.classList.add('hidden')
        updateChatHeader(username)
        socket.emit('getStatus', { username })
        await applyChatCfg()
    }

    function exitChatMode() {
        appShell.classList.remove('chat-open')
        tabViews.classList.remove('hidden')
        bottomNav.classList.remove('hidden')
        // Restore main tab panes display
        document.querySelectorAll('.tab-views > .tab-pane').forEach(p => p.style.display = '')
        // Clear message tab states
        document.querySelectorAll('#TabList .tab-pane.show.active').forEach(p => p.classList.remove('show','active'))
        document.querySelectorAll('button[data-bs-toggle="tab"].active').forEach(b => b.classList.remove('active'))
        Interlocutor.setUsername(null)
        CurrentRoom.SetName(null)
    }

    document.getElementById('topbarBack').addEventListener('click', exitChatMode)

    // ── Tab Switching ────────────────────────────────────────────────────────
    function switchTab(tab) {
        document.querySelectorAll('.tab-pane.active').forEach(p => p.classList.remove('active'))
        document.querySelectorAll('.nav-btn.active').forEach(b => b.classList.remove('active'))
        document.getElementById('pane' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active')
        const btn = document.querySelector(`.nav-btn[data-tab="${tab}"]`)
        btn.classList.add('active')
        const slider = document.getElementById('navBgSlider')
        if (slider) slider.style.left = btn.offsetLeft + 'px'
        if (tab === 'contacts') renderContactsTab()
        if (tab === 'calls') renderCallsTab()
        if (tab === 'profile') renderProfileTab()
    }

    // ── Contacts Tab ─────────────────────────────────────────────────────────
    function renderContactsTab() {
        fetch('/profile/contacts/list')
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById('contactsTabList')
                const contacts = data.contacts || []
                if (contacts.length === 0) {
                    list.innerHTML = '<div class="list-empty"><i class="fa-solid fa-address-book"></i><p>No contacts yet</p></div>'
                    return
                }
                list.innerHTML = contacts.map(c => {
                    const name = [c.firstName, c.lastName].filter(Boolean).join(' ') || c.username
                    const initial = (c.firstName || c.username).charAt(0).toUpperCase()
                    const avatar = c.avatar ? `<img src="/uploads/${c.avatar}" alt="${name}">` : ''
                    return `<li class="contact-item" onclick="OpenChat('${c.username}')">
                    <div class="contact-item-avatar">
                        ${avatar || `<div class="avatar-fallback-sm">${initial}</div>`}
                        <span class="contact-online" style="${c.isOnline ? '' : 'display:none;'}"></span>
                    </div>
                    <div class="contact-item-info">
                        <span class="contact-item-name">${name}</span>
                        <span class="contact-item-uname">@${c.username}</span>
                    </div>
                </li>`
                }).join('')
            })
            .catch(() => {})
    }

    function filterContacts(query) {
        const items = document.querySelectorAll('#contactsTabList .contact-item')
        items.forEach(item => {
            const name = item.querySelector('.contact-item-name').textContent.toLowerCase()
            item.style.display = name.includes(query.toLowerCase()) ? 'flex' : 'none'
        })
    }

    // ── Calls Tab ────────────────────────────────────────────────────────────
    function renderCallsTab() {
        fetch('/calls/history')
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById('callsTabList')
                const calls = data.calls || []
                if (calls.length === 0) {
                    list.innerHTML = '<div class="list-empty"><i class="fa-solid fa-phone"></i><p>No calls yet</p></div>'
                    return
                }
                list.innerHTML = calls.map(c => {
                    const isOutgoing = c.caller === CurrentUser.getUsername()
                    const icon = isOutgoing ? 'fa-phone-volume' : 'fa-phone'
                    const iconRotated = isOutgoing ? '' : 'style="transform:scaleX(-1)"'
                    const label = c.status === 'ended' ? (isOutgoing ? 'Outgoing' : 'Incoming') : c.status === 'declined' ? 'Declined' : 'Missed'
                    const duration = c.duration ? Math.floor(c.duration / 60) + 'm ' + (c.duration % 60) + 's' : ''
                    const date = new Date(c.created_at).toLocaleDateString()
                    const initial = (c.displayName || c.otherUser).charAt(0).toUpperCase()
                    return `<li class="call-item" onclick="OpenChat('${c.otherUser}')">
                    <div class="call-item-avatar">
                        <div class="avatar-fallback-sm">${initial}</div>
                    </div>
                    <div class="call-item-info">
                        <span class="call-item-name">${c.displayName || c.otherUser}</span>
                        <span class="call-item-meta ${c.status === 'missed' ? 'missed' : ''}">
                            <i class="fa-solid ${icon}" ${iconRotated}></i> ${label}${duration ? ' · ' + duration : ''}
                        </span>
                    </div>
                    <span class="call-item-date">${date}</span>
                </li>`
                }).join('')
            })
            .catch(() => {})
    }

