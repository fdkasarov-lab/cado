    // ── Chats Filter ─────────────────────────────────────────────────────────
    function filterChats(query) {
        const items = document.querySelectorAll('#iconList li')
        items.forEach(item => {
            const name = item.querySelector('.name')?.textContent?.toLowerCase() || ''
            item.style.display = name.includes(query.toLowerCase()) ? '' : 'none'
        })
    }

    function updateChatHeader(username) {
        const header   = document.getElementById('chatHeader')
        const avatarEl = document.getElementById('headerAvatar')
        const nameEl   = document.getElementById('headerName')
        if (!username) { header.style.display = 'none'; return }
        const displayName = typeof getDisplayName === 'function' ? getDisplayName(username) : String(username).split('@')[0]
        header.style.display = 'flex'
        nameEl.textContent = displayName
        const tabImg = document.querySelector(`#iconList button[data-username="${username}"] img.user-avatar`)
        if (tabImg && tabImg.getAttribute('src')) {
            avatarEl.innerHTML = `<img src="${tabImg.getAttribute('src')}" alt="${displayName}">`
        } else {
            avatarEl.textContent = displayName.charAt(0).toUpperCase()
        }
        const info = userStatus[username]
        updateStatusLabel(username, info?.online ? 'online' : 'offline')
    }

    /* ═══════════════════════════════════════════════════════════════
       TYPING
    ════════════════════════════════════════════════════════════════ */
    let typingTimer = null
    const input = document.getElementById('input')

    input.addEventListener('input', () => {
        if (!Interlocutor.getUsername() || !CurrentRoom.getName()) return
        socket.emit('typing', { room: CurrentRoom.getName(), sender: CurrentUser.getUsername(), receiver: Interlocutor.getUsername() })
        clearTimeout(typingTimer)
        typingTimer = setTimeout(() => {
            socket.emit('stopTyping', { room: CurrentRoom.getName(), sender: CurrentUser.getUsername(), receiver: Interlocutor.getUsername() })
        }, 2000)
    })

    /* ═══════════════════════════════════════════════════════════════
       CHAT CUSTOMISATION — per-user settings
    ═════════════════════════════════════════════════════════════════ */
    // ── local cache + last chat user (survives exitChatMode) ───────────────────
    var _chatCfgCache = {}
    var _lastChatUser = null

    function chatId() {
        if (CurrentRoom && CurrentRoom.getName()) return CurrentRoom.getName()
        if (_lastChatUser) return CurrentUser.getUsername() + '!@!@2@!@!' + _lastChatUser
        return null
    }

    function peerUsername() { return _lastChatUser }

    function chatCfgStorageKey(cid) {
        return 'chatCfg_' + CurrentUser.getUsername() + '_' + cid
    }

    function defaultChatConfig() {
        return {
            font: "'Inter', sans-serif",
            bubbleStyle: 'modern',
            fontSize: '14',
            sentColor: '#1A3A5C',
            receivedColor: '#21262D',
            bgColor: '',
            bgImage: '',
        }
    }

    function normalizeHexColor(value, fallback) {
        value = String(value || '')
        return /^#[0-9a-fA-F]{6}$/.test(value) ? value : fallback
    }

    function normalizeChatConfig(config) {
        var base = defaultChatConfig()
        config = config || {}
        return {
            font: config.font || base.font,
            bubbleStyle: ['modern','rounded','square','pill'].includes(config.bubbleStyle) ? config.bubbleStyle : base.bubbleStyle,
            fontSize: String(Math.min(20, Math.max(12, Number(config.fontSize) || 14))),
            sentColor: normalizeHexColor(config.sentColor, base.sentColor),
            receivedColor: normalizeHexColor(config.receivedColor, base.receivedColor),
            bgColor: normalizeHexColor(config.bgColor, ''),
            bgImage: String(config.bgImage || ''),
        }
    }

    async function loadChatConfig() {
        var cid = chatId()
        if (!cid) { _chatCfgCache = defaultChatConfig(); return _chatCfgCache }

        try {
            var r = await fetch('/api/chat-cfg/' + encodeURIComponent(cid), { credentials: 'include' })
            if (r.ok) {
                var d = await r.json()
                if (d.config && Object.keys(d.config).length > 0) {
                    _chatCfgCache = normalizeChatConfig(d.config)
                    try { localStorage.setItem(chatCfgStorageKey(cid), JSON.stringify(_chatCfgCache)) } catch(e) {}
                    return _chatCfgCache
                }
            }
        } catch(e) {}

        try {
            var personal = localStorage.getItem(chatCfgStorageKey(cid))
            if (personal) { _chatCfgCache = normalizeChatConfig(JSON.parse(personal)); return _chatCfgCache }

            var legacy = localStorage.getItem('chatCfg_' + cid)
            if (legacy) { _chatCfgCache = normalizeChatConfig(JSON.parse(legacy)); return _chatCfgCache }
        } catch(e) {}

        _chatCfgCache = defaultChatConfig()
        return _chatCfgCache
    }

    async function persistChatCfg() {
        var cid = chatId()
        if (!cid) return { ok: false }
        var response = await fetch('/api/chat-cfg/save', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chatId: cid, config: _chatCfgCache })
        })
        if (!response.ok) throw new Error('Failed to save chat appearance')
        var data = await response.json().catch(function(){ return {} })
        if (data.config) _chatCfgCache = normalizeChatConfig(data.config)
        try { localStorage.setItem(chatCfgStorageKey(cid), JSON.stringify(_chatCfgCache)) } catch(e) {}
        return data
    }

    function cssUrl(value) {
        return 'url("' + String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '")'
    }

    function applyCfgFromCache() {
        var cfg = normalizeChatConfig(_chatCfgCache)
        _chatCfgCache = cfg
        var r = document.documentElement.style

        r.setProperty('--chat-font-family', cfg.font)
        r.setProperty('--font-size', cfg.fontSize + 'px')

        var radius = '14px'
        if (cfg.bubbleStyle === 'rounded') radius = '22px'
        else if (cfg.bubbleStyle === 'square') radius = '6px'
        else if (cfg.bubbleStyle === 'pill') radius = '999px'
        r.setProperty('--message-radius', radius)

        r.setProperty('--bubble-sent-bg', cfg.sentColor)
        r.setProperty('--bubble-received-bg', cfg.receivedColor)
        r.setProperty('--bubble-sent', cfg.sentColor)
        r.setProperty('--bubble-received', cfg.receivedColor)

        if (cfg.bgImage) {
            r.setProperty('--chat-bg-image', cssUrl(cfg.bgImage))
            r.setProperty('--chat-bg', 'transparent')
        } else if (cfg.bgColor) {
            r.setProperty('--chat-bg-image', 'none')
            r.setProperty('--chat-bg', cfg.bgColor)
        } else {
            r.setProperty('--chat-bg-image', 'none')
            r.setProperty('--chat-bg', 'transparent')
        }
    }

    async function applyChatCfg() {
        await loadChatConfig()
        applyCfgFromCache()
    }

    function readChatCfgForm(scope) {
        var s = function(id) { return (scope ? scope.querySelector('#' + id) : null) || document.getElementById(id) }
        var bgMode = s('cfgBgMode')?.value || 'color'
        var imageValue = s('cfgBgImage')?.value || ''
        var colorValue = s('cfgBgColor')?.value || ''

        var raw = normalizeChatConfig({
            font: s('cfgFont')?.value,
            bubbleStyle: s('cfgBubbleStyle')?.value,
            fontSize: s('cfgFontSize')?.value,
            sentColor: s('cfgSentColor')?.value,
            receivedColor: s('cfgReceivedColor')?.value,
            bgColor: bgMode === 'color' ? colorValue : '',
            bgImage: bgMode === 'image' ? imageValue : '',
        })
        if (bgMode === 'none') {
            raw.bgColor = ''
            raw.bgImage = ''
        }
        return raw
    }

    async function applyAndSaveChatCfg(scope) {
        if (!chatId()) return false
        var previous = _chatCfgCache
        _chatCfgCache = readChatCfgForm(scope)
        try {
            await persistChatCfg()
            applyCfgFromCache()
            return true
        } catch (error) {
            _chatCfgCache = previous
            applyCfgFromCache()
            throw error
        }
    }

    function closeChatCfgPanel() {
        var p = document.getElementById('ChatCfgPanel')
        if (!p) return
        p.classList.remove('open')
        applyChatCfg().catch(function(){})
        setTimeout(function() { if (p.parentNode) p.parentNode.removeChild(p) }, 380)
    }

    function openChatCfgPanel() {
        var existing = document.getElementById('ChatCfgPanel')
        if (existing) { closeChatCfgPanel(); return }

        var panel = document.createElement('div')
        panel.className = 'panel'
        panel.id = 'ChatCfgPanel'
        panel.innerHTML =
            '<div class="profile-panel-header">' +
            '<button class="profile-close-btn" onclick="closeChatCfgPanel()"><i class="fa-solid fa-chevron-down"></i></button>' +
            '<span class="profile-panel-title">Chat Appearance</span>' +
            '<div style="width:36px;"></div>' +
            '</div>' +
            '<div class="profile-info-section" style="margin:0 16px 16px;border:none;background:transparent;">' +
            '<div id="chatCfgInner">Loading...</div>' +
            '</div>'

        document.body.appendChild(panel)
        requestAnimationFrame(function() { panel.classList.add('open') })
        renderChatCfgPanel(panel.querySelector('#chatCfgInner'))
    }

    async function saveChatCfgButton(button) {
        var scope = button.closest('.panel') || button.closest('.profile-info-section') || document
        var original = button.innerHTML
        button.disabled = true
        button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving'
        try {
            await applyAndSaveChatCfg(scope)
            button.innerHTML = '<i class="fa-solid fa-check"></i> Saved'
        } catch(e) {
            console.error(e)
            button.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Failed'
        } finally {
            setTimeout(function(){ button.disabled = false; button.innerHTML = original }, 1400)
        }
    }

    function setCfgBgColor(color, scope) {
        var s = scope || document
        var picker = s.querySelector('#cfgBgColor')
        var mode = s.querySelector('#cfgBgMode')
        var image = s.querySelector('#cfgBgImage')
        var label = s.querySelector('#bgFileDisplay')
        if (picker) picker.value = color
        if (mode) mode.value = 'color'
        if (image) image.value = ''
        if (label) label.textContent = 'Color set'
        applyCfgPreview(s)
    }

    function resetCfgBg(scope) {
        var s = scope || document
        var mode = s.querySelector('#cfgBgMode')
        var image = s.querySelector('#cfgBgImage')
        var label = s.querySelector('#bgFileDisplay')
        if (mode) mode.value = 'none'
        if (image) image.value = ''
        if (label) label.textContent = ''
        applyCfgPreview(scope)
    }

    function setCfgBubbleColor(kind, color, scope) {
        var s = scope || document
        var inputId = kind === 'sent' ? 'cfgSentColor' : 'cfgReceivedColor'
        var input = s.querySelector('#' + inputId)
        if (!input) return
        input.value = color
        s.querySelectorAll('[data-cfg-bubble="' + kind + '"]').forEach(function(button) {
            button.classList.toggle('selected', button.dataset.color === color)
            button.setAttribute('aria-pressed', button.dataset.color === color ? 'true' : 'false')
        })
        applyCfgPreview(s)
    }

    function applyCfgPreview(scope) {
        var s = scope || document
        var preview = s.querySelector('.chat-cfg-preview')
        if (!preview) return

        var cfg = readChatCfgForm(s)
        var radius = '14px'
        if (cfg.bubbleStyle === 'rounded') radius = '22px'
        else if (cfg.bubbleStyle === 'square') radius = '6px'
        else if (cfg.bubbleStyle === 'pill') radius = '999px'

        preview.style.setProperty('--cfg-preview-font', cfg.font)
        preview.style.setProperty('--cfg-preview-font-size', cfg.fontSize + 'px')
        preview.style.setProperty('--cfg-preview-radius', radius)
        preview.style.setProperty('--cfg-preview-sent-bg', cfg.sentColor)
        preview.style.setProperty('--cfg-preview-received-bg', cfg.receivedColor)
        preview.style.setProperty('--cfg-preview-bg', cfg.bgColor || 'var(--panel-color)')
        preview.style.setProperty('--cfg-preview-bg-image', cfg.bgImage ? cssUrl(cfg.bgImage) : 'none')
    }

    async function handleCfgBgFile(input) {
        var file = input.files && input.files[0]
        if (!file) return
        var scope = input.closest('.panel') || input.closest('.profile-info-section') || document
        var label = scope.querySelector('#bgFileDisplay')
        if (label) label.textContent = 'Uploading...'

        var data = new FormData()
        data.append('files', file)
        try {
            var response = await fetch('/chat_upload', { method: 'POST', body: data })
            if (!response.ok) throw new Error('Upload failed')
            var result = await response.json()
            var filename = result.files && result.files[0]
            if (!filename) throw new Error('Upload failed')
            scope.querySelector('#cfgBgImage').value = '/uploads/' + filename
            scope.querySelector('#cfgBgMode').value = 'image'
            if (label) label.textContent = file.name
            applyCfgPreview(scope)
        } catch(e) {
            console.error(e)
            if (label) label.textContent = 'Upload failed'
        } finally {
            input.value = ''
        }
    }

    async function renderChatCfgPanel(container) {
        var cfg = await loadChatConfig()
        var who = peerUsername()
        var lbl = document.getElementById('chatCfgLabel')
        if (lbl) lbl.textContent = who ? 'for ' + (typeof getDisplayName === 'function' ? getDisplayName(who) : who) : 'no chat selected'
        var inner = container || document.getElementById('chatCfgInner')
