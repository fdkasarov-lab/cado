        var bgMode = cfg.bgImage ? 'image' : (cfg.bgColor ? 'color' : 'none')
        var bgColor = cfg.bgColor || '#0D1117'
        var presets = ['#0D1117','#1A1B2E','#1B2A1E','#2D1B1B','#1B2D2B','#2C1B2D','#1C1C1C','#1E2A3A']
        var bubblePresets = [
            ['Blue', '#3B82F6'], ['Sky', '#0EA5E9'], ['Cyan', '#06B6D4'], ['Emerald', '#10B981'],
            ['Green', '#22C55E'], ['Lime', '#84CC16'], ['Amber', '#F59E0B'], ['Orange', '#F97316'],
            ['Red', '#EF4444'], ['Rose', '#F43F5E'], ['Pink', '#EC4899'], ['Purple', '#8B5CF6'],
            ['Violet', '#7C3AED'], ['Brown', '#A16207'], ['Slate', '#475569'], ['Charcoal', '#334155']
        ]

        inner.innerHTML = `
      <div class="chat-cfg-preview">
        <div class="chat-cfg-preview-bubble received">Incoming message preview</div>
        <div class="chat-cfg-preview-bubble sent">Your message preview</div>
      </div>
      <div class="profile-info-row">
        <div class="profile-info-icon"><i class="fa-solid fa-font"></i></div>
        <div class="profile-info-content" style="flex:1;">
          <span class="profile-info-label">Font</span>
          <select id="cfgFont" style="width:100%;background:var(--panel-color);color:var(--text-color);border:1px solid var(--border-strong);border-radius:8px;padding:8px 10px;font-size:13px;outline:none;">
            ${fonts.map(function(f) { return '<option value="' + f + '"' + (cfg.font === f ? ' selected' : '') + '>' + f.replace(/,?\s*sans-serif/g,'').replace(/'/g,'') + '</option>' }).join('')}
          </select>
        </div>
      </div>
      <div class="profile-info-row">
        <div class="profile-info-icon"><i class="fa-solid fa-comment"></i></div>
        <div class="profile-info-content" style="flex:1;">
