        if (!chatId() || !who) {
            inner.innerHTML = '<div class="profile-info-content" style="padding:14px 16px;"><span class="profile-info-value" style="color:var(--text-muted);font-size:13px;">Open a chat first to customize its appearance.</span></div>'
            return
