<!-- ══ CALL MODAL ═══════════════════════════════════════════════════════════ -->
<div class="call-modal" id="callModal" style="display:none;">
    <button class="call-modal-minimize" id="callMinimizeBtn" onclick="minimizeCall()" title="Minimize">
        <i class="fa-solid fa-minus"></i>
    </button>
    <div class="call-modal-bg"></div>
    <div class="call-modal-content">
        <div class="call-modal-avatar" id="callModalAvatar"></div>
        <div class="call-modal-name" id="callModalName">—</div>
        <div class="call-modal-status" id="callModalStatus">Calling…</div>
        <div class="call-modal-controls">
            <div class="call-secondary-btns" id="callSecondaryBtns">
                <button class="call-secondary-btn" id="muteMicBtn" onclick="toggleMute()">
                    <div class="call-secondary-icon"><i class="fa-solid fa-microphone"></i></div>
                    <span class="call-secondary-label">Mute</span>
                </button>
                <button class="call-secondary-btn" id="speakerBtn" onclick="toggleSpeaker()">
                    <div class="call-secondary-icon"><i class="fa-solid fa-volume-high"></i></div>
                    <span class="call-secondary-label">Speaker</span>
                </button>
            </div>
            <div class="call-primary-btns" id="callPrimaryBtns">
                <button class="call-primary-btn end" id="cancelCallBtn" onclick="endCall()">
                    <div class="call-primary-icon"><i class="fa-solid fa-phone-slash"></i></div>
                    <span class="call-primary-label">End</span>
                </button>
            </div>
        </div>
